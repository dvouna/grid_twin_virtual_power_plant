# InfluxDB Cloud Credentials (for MCP Server / Cloud Run)
INFLUX_CLOUD_URL=https://us-east-1-1.aws.cloud2.influxdata.com
INFLUX_CLOUD_TOKEN=your-cloud-token-here
INFLUX_CLOUD_ORG=Energy Simulation
INFLUX_CLOUD_BUCKET=energy

# InfluxDB Local Credentials (for Consumer Script)
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-local-token-here
INFLUX_ORG=myorg
INFLUX_BUCKET=energy

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Gemini LLM (Dashboard AI Assistant)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# MCP Server (GridIntelligence) URL — set to Cloud Run URL in production
MCP_SERVER_URL=http://localhost:8080

